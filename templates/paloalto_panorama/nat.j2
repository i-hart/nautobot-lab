{# ── Palo Alto Panorama: NAT Rules ────────────────────────────── #}

{% for nat in device.fw_nat_rules | sort(attribute='index') %}
{# --- zones --- #}
{% for zone in nat.source_zones %}
set device-group {{ device_group }} pre-rulebase nat rules "{{ nat.name }}" from {{ zone.name }}
{% endfor %}
{% for zone in nat.destination_zones %}
set device-group {{ device_group }} pre-rulebase nat rules "{{ nat.name }}" to {{ zone.name }}
{% endfor %}

{# --- original match --- #}
{% for addr in nat.original_source_addresses %}
set device-group {{ device_group }} pre-rulebase nat rules "{{ nat.name }}" source {{ addr.name }}
{% endfor %}
{% for addr in nat.original_destination_addresses %}
set device-group {{ device_group }} pre-rulebase nat rules "{{ nat.name }}" destination {{ addr.name }}
{% endfor %}
{% if nat.original_service %}
set device-group {{ device_group }} pre-rulebase nat rules "{{ nat.name }}" service {{ nat.original_service.name }}
{% endif %}

{# --- translation --- #}
{% if nat.nat_type | lower == "source" and nat.translated_source %}
set device-group {{ device_group }} pre-rulebase nat rules "{{ nat.name }}" source-translation dynamic-ip-and-port translated-address {{ nat.translated_source.name }}
{% elif nat.nat_type | lower == "destination" and nat.translated_destination %}
set device-group {{ device_group }} pre-rulebase nat rules "{{ nat.name }}" destination-translation translated-address {{ nat.translated_destination.name }}
{% if nat.translated_port %}
set device-group {{ device_group }} pre-rulebase nat rules "{{ nat.name }}" destination-translation translated-port {{ nat.translated_port }}
{% endif %}
{% elif nat.nat_type | lower == "static" and nat.translated_source %}
set device-group {{ device_group }} pre-rulebase nat rules "{{ nat.name }}" source-translation static-ip translated-address {{ nat.translated_source.name }}
{% endif %}

{% if nat.description %}
set device-group {{ device_group }} pre-rulebase nat rules "{{ nat.name }}" description "{{ nat.description }}"
{% endif %}

{% endfor %}
