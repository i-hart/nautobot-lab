{# ── Palo Alto Panorama: Service Objects & Groups ─────────────── #}

{% for svc in device.fw_service_objects %}
set device-group {{ device_group }} service {{ svc.name }} protocol {{ svc.protocol | lower }} port {{ svc.port }}
{% if svc.description %}
set device-group {{ device_group }} service {{ svc.name }} description "{{ svc.description }}"
{% endif %}
{% endfor %}

{% for grp in device.fw_service_object_groups %}
{% for member in grp.service_objects %}
set device-group {{ device_group }} service-group {{ grp.name }} members {{ member.name }}
{% endfor %}
{% endfor %}
