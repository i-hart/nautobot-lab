{# ── Palo Alto Panorama: Address Objects & Groups ─────────────── #}
{# Context: device.fw_address_objects, device.fw_address_object_groups #}

{# --- Individual address objects --- #}
{% for addr in device.fw_address_objects %}
{% if addr.fqdn %}
set device-group {{ device_group }} address {{ addr.name }} fqdn {{ addr.fqdn }}
{% elif addr.ip_range %}
set device-group {{ device_group }} address {{ addr.name }} ip-range {{ addr.ip_range.start_address }}-{{ addr.ip_range.end_address }}
{% elif addr.ip_address %}
set device-group {{ device_group }} address {{ addr.name }} ip-netmask {{ addr.ip_address.host }}
{% endif %}
{% if addr.description %}
set device-group {{ device_group }} address {{ addr.name }} description "{{ addr.description }}"
{% endif %}
{% endfor %}

{# --- Address groups --- #}
{% for grp in device.fw_address_object_groups %}
{% for member in grp.address_objects %}
set device-group {{ device_group }} address-group {{ grp.name }} static {{ member.name }}
{% endfor %}
{% if grp.description %}
set device-group {{ device_group }} address-group {{ grp.name }} description "{{ grp.description }}"
{% endif %}
{% endfor %}
