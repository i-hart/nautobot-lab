{# ================================================================
   FortiGate — Golden Config Entry Point

   Data from GraphQL: device → virtual_systems → logical_groups
   VDOM is resolved from virtual_system name.
   ================================================================ #}

{% for vsys in device.virtual_systems %}
{% set vdom = vsys.name | default("root") %}

{% if vdom != "root" %}
config vdom
    edit {{ vdom }}
end
{% endif %}

{% for lg in vsys.logical_groups %}

{# ── Address Objects ─────────────────────────────────────── #}
{% for addr in lg.address_objects %}
config firewall address
    edit "{{ addr.name }}"
{% if addr.fqdn %}
        set type fqdn
        set fqdn "{{ addr.fqdn.name }}"
{% elif addr.ip_range %}
        set type iprange
        set start-ip {{ addr.ip_range.start_address }}
        set end-ip {{ addr.ip_range.end_address }}
{% elif addr.ip_address %}
        set type ipmask
        set subnet {{ addr.ip_address.host }}
{% elif addr.prefix %}
        set type ipmask
        set subnet {{ addr.prefix.prefix }}
{% endif %}
{% if addr.description %}
        set comment "{{ addr.description }}"
{% endif %}
    next
end
{% endfor %}

{# ── Address Groups ──────────────────────────────────────── #}
{% for grp in lg.address_object_groups %}
config firewall addrgrp
    edit "{{ grp.name }}"
        set member {% for m in grp.address_objects %}"{{ m.name }}" {% endfor %}

{% if grp.description %}
        set comment "{{ grp.description }}"
{% endif %}
    next
end
{% endfor %}

{# ── Service Objects ─────────────────────────────────────── #}
{% for svc in lg.service_objects %}
config firewall service custom
    edit "{{ svc.name }}"
{% if svc.ip_protocol | lower == "tcp" %}
        set protocol TCP/UDP/SCTP
        set tcp-portrange {{ svc.port }}
{% elif svc.ip_protocol | lower == "udp" %}
        set protocol TCP/UDP/SCTP
        set udp-portrange {{ svc.port }}
{% elif svc.ip_protocol | lower == "icmp" %}
        set protocol ICMP
{% else %}
        set protocol IP
{% endif %}
{% if svc.description %}
        set comment "{{ svc.description }}"
{% endif %}
    next
end
{% endfor %}

{# ── Service Groups ──────────────────────────────────────── #}
{% for grp in lg.service_object_groups %}
config firewall service group
    edit "{{ grp.name }}"
        set member {% for m in grp.service_objects %}"{{ m.name }}" {% endfor %}

    next
end
{% endfor %}

{# ── Security Policies ───────────────────────────────────── #}
{% set ns = namespace(pid=device.config_context.policy_id_start | default(1000) | int) %}

{% for rule in lg.policy_rules | sort(attribute='index') %}
config firewall policy
    edit {{ ns.pid }}
        set name "{{ rule.name }}"
{% if rule.source_zone %}
        set srcintf "{{ rule.source_zone.name }}"
{% endif %}
{% if rule.destination_zone %}
        set dstintf "{{ rule.destination_zone.name }}"
{% endif %}

{% if rule.source_address_groups %}
        set srcaddr {% for g in rule.source_address_groups %}"{{ g.name }}" {% endfor %}

{% elif rule.source_addresses %}
        set srcaddr {% for a in rule.source_addresses %}"{{ a.name }}" {% endfor %}

{% else %}
        set srcaddr "all"
{% endif %}

{% if rule.destination_address_groups %}
        set dstaddr {% for g in rule.destination_address_groups %}"{{ g.name }}" {% endfor %}

{% elif rule.destination_addresses %}
        set dstaddr {% for a in rule.destination_addresses %}"{{ a.name }}" {% endfor %}

{% else %}
        set dstaddr "all"
{% endif %}

{% if rule.destination_services or rule.destination_service_groups %}
        set service {% for s in rule.destination_services %}"{{ s.name }}" {% endfor %}{% for g in rule.destination_service_groups %}"{{ g.name }}" {% endfor %}

{% else %}
        set service "ALL"
{% endif %}

        set action {{ "accept" if rule.action | lower == "allow" else "deny" }}
        set schedule "always"
{% if rule.log %}
        set logtraffic all
{% else %}
        set logtraffic disable
{% endif %}
{% if rule.description %}
        set comments "{{ rule.description }}"
{% endif %}
    next
end
{% set ns.pid = ns.pid + 1 %}
{% endfor %}

{% endfor %}
{% endfor %}
