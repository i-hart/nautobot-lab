{# ── FortiGate: NAT Rules ─────────────────────────────────────── #}
{# FortiGate uses VIPs for DNAT and IP Pools for SNAT.             #}

{# --- Destination NAT (VIPs) --- #}
{% for nat in device.fw_nat_rules | sort(attribute='index') if nat.nat_type | lower == "destination" %}
config firewall vip
    edit "{{ nat.name }}"
        set extintf {% for z in nat.destination_zones %}"{{ z.name }}" {% endfor %}

{% if nat.original_destination_addresses %}
        set extip {{ nat.original_destination_addresses[0].name }}
{% endif %}
{% if nat.translated_destination %}
        set mappedip {{ nat.translated_destination.name }}
{% endif %}
{% if nat.translated_port %}
        set portforward enable
{% if nat.original_service %}
        set extport {{ nat.original_service.name }}
{% endif %}
        set mappedport {{ nat.translated_port }}
{% endif %}
{% if nat.description %}
        set comment "{{ nat.description }}"
{% endif %}
    next
end
{% endfor %}

{# --- Source NAT (IP Pools) --- #}
{% for nat in device.fw_nat_rules | sort(attribute='index') if nat.nat_type | lower == "source" %}
config firewall ippool
    edit "{{ nat.name }}"
{% if nat.translated_source %}
        set startip {{ nat.translated_source.name }}
        set endip {{ nat.translated_source.name }}
{% endif %}
{% if nat.description %}
        set comments "{{ nat.description }}"
{% endif %}
    next
end
{% endfor %}
