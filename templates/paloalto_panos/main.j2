{# ================================================================
   Palo Alto Panorama — Golden Config Intended Configuration

   Data comes from GraphQL query: firewall_policy_context
   Path: device → firewall_policies → policy_rules

   Each Policy maps to a device-group + rulebase combination.
   Policy names follow pattern: {device-group}-{PRE|POST}
   ================================================================ #}

{% for policy in firewall_policies %}
{# Extract device-group and rulebase from policy name #}
{% set policy_parts = policy.name.rsplit('-', 1) %}
{% set device_group = policy_parts[0] if policy_parts | length > 1 else policy.name %}
{% set rb_label = policy_parts[-1] | upper %}
{% set rb = "pre-rulebase" if rb_label == "PRE" else "post-rulebase" %}

{% for rule in policy.policy_rules | sort(attribute="index") %}
{# ── Zones ──────────────────────────────────────────────── #}
{% if rule.source_zone %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" from {{ rule.source_zone.name }}
{% else %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" from any
{% endif %}
{% if rule.destination_zone %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" to {{ rule.destination_zone.name }}
{% else %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" to any
{% endif %}

{# ── Source Addresses ───────────────────────────────────── #}
{% if rule.source_address_groups %}
{% for grp in rule.source_address_groups %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" source {{ grp.name }}
{% endfor %}
{% elif rule.source_addresses %}
{% for addr in rule.source_addresses %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" source {{ addr.name }}
{% endfor %}
{% else %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" source any
{% endif %}

{# ── Destination Addresses ──────────────────────────────── #}
{% if rule.destination_address_groups %}
{% for grp in rule.destination_address_groups %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" destination {{ grp.name }}
{% endfor %}
{% elif rule.destination_addresses %}
{% for addr in rule.destination_addresses %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" destination {{ addr.name }}
{% endfor %}
{% else %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" destination any
{% endif %}

{# ── Applications ───────────────────────────────────────── #}
{% if rule.applications %}
{% for app in rule.applications %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" application {{ app.name }}
{% endfor %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" service application-default
{% elif rule.application_groups %}
{% for grp in rule.application_groups %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" application {{ grp.name }}
{% endfor %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" service application-default
{% else %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" application any
{# ── Services (only when no app-id) ─────────────────────── #}
{% if rule.destination_services %}
{% for svc in rule.destination_services %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" service {{ svc.name }}
{% endfor %}
{% elif rule.destination_service_groups %}
{% for grp in rule.destination_service_groups %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" service {{ grp.name }}
{% endfor %}
{% else %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" service any
{% endif %}
{% endif %}

{# ── Action & Logging ───────────────────────────────────── #}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" action {{ rule.action | lower }}
{% if rule.log %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" log-end yes
{% endif %}

{# ── Description ────────────────────────────────────────── #}
{% if rule.description %}
set device-group {{ device_group }} {{ rb }} security rules "{{ rule.name }}" description "{{ rule.description }}"
{% endif %}

{% endfor %}
{% endfor %}
