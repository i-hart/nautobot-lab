{# ── Cisco ASA: Network Objects & Groups ──────────────────────── #}

{% for addr in device.fw_address_objects %}
{% if addr.fqdn %}
object network {{ addr.name }}
 fqdn {{ addr.fqdn }}
{% elif addr.ip_range %}
object network {{ addr.name }}
 range {{ addr.ip_range.start_address }} {{ addr.ip_range.end_address }}
{% elif addr.ip_address and '/32' in addr.ip_address.host %}
object network {{ addr.name }}
 host {{ addr.ip_address.host | replace('/32', '') }}
{% elif addr.ip_address %}
object network {{ addr.name }}
 subnet {{ addr.ip_address.host }}
{% endif %}
{% if addr.description %}
 description {{ addr.description }}
{% endif %}
!
{% endfor %}

{% for grp in device.fw_address_object_groups %}
object-group network {{ grp.name }}
{% if grp.description %}
 description {{ grp.description }}
{% endif %}
{% for member in grp.address_objects %}
 network-object object {{ member.name }}
{% endfor %}
!
{% endfor %}
