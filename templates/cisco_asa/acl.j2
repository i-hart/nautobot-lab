{# ── Cisco ASA: Access Control Lists ──────────────────────────── #}
{# One named ACL per source zone, bound to the interface.          #}

{% for rule in device.fw_policy_rules | sort(attribute='index') %}
{% set acl_name = rule.source_zones[0].name + "_access_in" %}
{% set action_word = "permit" if rule.action | lower == "allow" else "deny" %}

{# Build source list: prefer groups, fall back to individual addresses #}
{% set src_list = rule.source_address_groups if rule.source_address_groups else rule.source_addresses %}
{% set dst_list = rule.destination_address_groups if rule.destination_address_groups else rule.destination_addresses %}
{% set svc_list = rule.service_groups + rule.service_objects if (rule.service_groups or rule.service_objects) else [] %}

{% for src in src_list %}
{% for dst in dst_list %}
{% for svc in svc_list %}
access-list {{ acl_name }} extended {{ action_word }} object-group {{ svc.name }} object-group {{ src.name }} object-group {{ dst.name }}
{% endfor %}
{% endfor %}
{% endfor %}
{% if rule.description %}
! {{ rule.name }}: {{ rule.description }}
{% endif %}
{% endfor %}

{# --- Bind ACLs to interfaces (deduplicated) --- #}
{% set seen_zones = [] %}
{% for rule in device.fw_policy_rules %}
{% for zone in rule.source_zones %}
{% if zone.name not in seen_zones %}
access-group {{ zone.name }}_access_in in interface {{ zone.name }}
{% if seen_zones.append(zone.name) %}{% endif %}
{% endif %}
{% endfor %}
{% endfor %}
