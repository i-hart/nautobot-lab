{# ================================================================
   Cisco ASA — Golden Config Entry Point

   Data from GraphQL: device → virtual_systems → logical_groups
   Security context from virtual_system name.
   ================================================================ #}

{% for vsys in device.virtual_systems %}
{% set security_context = vsys.name | default("system") %}

{% if security_context != "system" %}
changeto context {{ security_context }}
{% endif %}

{% for lg in vsys.logical_groups %}

{# ── Network Objects ─────────────────────────────────────── #}
{% for addr in lg.address_objects %}
{% if addr.fqdn %}
object network {{ addr.name }}
 fqdn {{ addr.fqdn.name }}
{% elif addr.ip_range %}
object network {{ addr.name }}
 range {{ addr.ip_range.start_address }} {{ addr.ip_range.end_address }}
{% elif addr.ip_address and '/32' in addr.ip_address.host %}
object network {{ addr.name }}
 host {{ addr.ip_address.host | replace('/32', '') }}
{% elif addr.ip_address %}
object network {{ addr.name }}
 subnet {{ addr.ip_address.host }}
{% elif addr.prefix %}
object network {{ addr.name }}
 subnet {{ addr.prefix.prefix }}
{% endif %}
{% if addr.description %}
 description {{ addr.description }}
{% endif %}
!
{% endfor %}

{# ── Network Object Groups ───────────────────────────────── #}
{% for grp in lg.address_object_groups %}
object-group network {{ grp.name }}
{% if grp.description %}
 description {{ grp.description }}
{% endif %}
{% for member in grp.address_objects %}
 network-object object {{ member.name }}
{% endfor %}
!
{% endfor %}

{# ── Service Objects ─────────────────────────────────────── #}
{% for svc in lg.service_objects %}
object service {{ svc.name }}
 service {{ svc.ip_protocol | lower }} destination eq {{ svc.port }}
{% if svc.description %}
 description {{ svc.description }}
{% endif %}
!
{% endfor %}

{# ── Service Object Groups ───────────────────────────────── #}
{% for grp in lg.service_object_groups %}
object-group service {{ grp.name }}
{% if grp.description %}
 description {{ grp.description }}
{% endif %}
{% for member in grp.service_objects %}
 service-object object {{ member.name }}
{% endfor %}
!
{% endfor %}

{# ── Access Control Lists ────────────────────────────────── #}
{% for rule in lg.policy_rules | sort(attribute='index') %}
{% set action_word = "permit" if rule.action | lower == "allow" else "deny" %}
{% set acl_name = (rule.source_zone.name if rule.source_zone else "inside") + "_access_in" %}

{% set src_list = rule.source_address_groups if rule.source_address_groups else rule.source_addresses %}
{% set dst_list = rule.destination_address_groups if rule.destination_address_groups else rule.destination_addresses %}
{% set svc_list = rule.destination_service_groups + rule.destination_services if (rule.destination_service_groups or rule.destination_services) else [] %}

{% for src in src_list %}
{% for dst in dst_list %}
{% for svc in svc_list %}
access-list {{ acl_name }} extended {{ action_word }} object-group {{ svc.name }} object-group {{ src.name }} object-group {{ dst.name }}
{% endfor %}
{% endfor %}
{% endfor %}
{% if rule.description %}
! {{ rule.name }}: {{ rule.description }}
{% endif %}
{% endfor %}

{# ── Bind ACLs to interfaces ────────────────────────────── #}
{% set seen_zones = [] %}
{% for rule in lg.policy_rules %}
{% if rule.source_zone and rule.source_zone.name not in seen_zones %}
access-group {{ rule.source_zone.name }}_access_in in interface {{ rule.source_zone.name }}
{% if seen_zones.append(rule.source_zone.name) %}{% endif %}
{% endif %}
{% endfor %}

{% endfor %}
{% endfor %}
